{
  "name": "pathik-backend",
  "version": "3.0.0",
  "description": "Pathik — Dhaka public transit backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/seed.ts",
    "test": "jest --forceExit --detectOpenHandles",
